# ===== General =====
NODE_ENV=development        # development | test | production
LOG_LEVEL=info              # pino level: trace|debug|info|warn|error|fatal
BOT_PORT=3000
ADMIN_PORT=3001
ADMIN_API_TOKEN=            # REQUIRED in production; dev fallback 'dev-token-change-me' if unset

# ===== MySQL =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mpcb
MYSQL_PASSWORD=mpcb_pw
MYSQL_DATABASE=mpcb
MYSQL_ROOT_PASSWORD=rootpw  # only used by docker-compose dev to bootstrap

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333             # only used by docker-compose dev

# ===== Embeddings =====
EMBEDDING_URL=https://api.siliconflow.cn
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ===== LLM providers (placeholders — replace with real keys) =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=           # Tongyi (Aliyun DashScope)
DEEPSEEK_API_KEY=

# ===== WeChat Work =====
WECHAT_TOKEN=                # callback verification token
WECHAT_API_BASE=https://qyapi.weixin.qq.com
WECHAT_CORP_ID=              # corp ID for gettoken endpoint
WECHAT_CORP_SECRET=          # corp secret for gettoken endpoint

# ===== Microsoft Teams =====
TEAMS_APP_ID=
TEAMS_APP_SECRET=

# ===== DingTalk =====
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# ===== Admin web (Next.js build-time public var) =====
NEXT_PUBLIC_BOT_URL=http://localhost:3000
